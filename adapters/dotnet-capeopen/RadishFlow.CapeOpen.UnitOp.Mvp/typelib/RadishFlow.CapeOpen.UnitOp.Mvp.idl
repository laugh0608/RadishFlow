// RadishFlow.CapeOpen.UnitOp.Mvp.idl
//
// 说明：
// - 该 IDL 是为 DWSIM / COFE 这类依赖 IDispatch + TypeInfo 的 CAPE-OPEN 宿主准备的
// - 当前仓库尚未包含可用的 MIDL 工具链，因此该文件先作为冻结的类型库真相源落库
// - 后续需要在可用的 Windows SDK / Visual Studio 环境中编译为
//   RadishFlow.CapeOpen.UnitOp.Mvp.tlb，并通过 ComHostTypeLibrary/注册脚本完成注册

import "oaidl.idl";
import "ocidl.idl";

typedef enum CapeValidationStatus
{
    NotValidated = 0,
    Invalid = 1,
    Valid = 2
} CapeValidationStatus;

typedef enum CapeParamType
{
    CAPE_REAL = 0,
    CAPE_INT = 1,
    CAPE_OPTION = 2,
    CAPE_BOOLEAN = 3,
    CAPE_ARRAY = 4
} CapeParamType;

typedef enum CapeParamMode
{
    CAPE_INPUT = 0,
    CAPE_OUTPUT = 1,
    CAPE_INPUT_OUTPUT = 2
} CapeParamMode;

typedef enum CapePortDirection
{
    CAPE_INLET = 0,
    CAPE_OUTLET = 1,
    CAPE_INLET_OUTLET = 2
} CapePortDirection;

typedef enum CapePortType
{
    CAPE_MATERIAL = 0,
    CAPE_ENERGY = 1,
    CAPE_INFORMATION = 2,
    CAPE_ANY = 3
} CapePortType;

[
    object,
    uuid(678C0990-7D66-11D2-A67D-00105A42887F),
    dual,
    nonextensible,
    oleautomation,
    pointer_default(unique)
]
interface ICapeIdentification : IDispatch
{
    [id(1), propget] HRESULT ComponentName([out, retval] BSTR* value);
    [id(1), propput] HRESULT ComponentName([in] BSTR value);

    [id(2), propget] HRESULT ComponentDescription([out, retval] BSTR* value);
    [id(2), propput] HRESULT ComponentDescription([in] BSTR value);
};

[
    object,
    uuid(678C099A-0093-11D2-A67D-00105A42887F),
    dual,
    nonextensible,
    oleautomation,
    pointer_default(unique)
]
interface ICapeCollection : IDispatch
{
    [id(1)] HRESULT Item([in] VARIANT index, [out, retval] IDispatch** value);
    [id(2)] HRESULT Count([out, retval] LONG* value);
};

[
    object,
    uuid(678C099C-0093-11D2-A67D-00105A42887F),
    dual,
    nonextensible,
    oleautomation,
    pointer_default(unique)
]
interface ICapeParameterSpec : IDispatch
{
    [id(1), propget] HRESULT Type([out, retval] CapeParamType* value);
    [id(2), propget] HRESULT Dimensionality([out, retval] SAFEARRAY(double)* value);
};

[
    object,
    uuid(678C09A0-0093-11D2-A67D-00105A42887F),
    dual,
    nonextensible,
    oleautomation,
    pointer_default(unique)
]
interface ICapeParameter : IDispatch
{
    [id(1), propget] HRESULT Specification([out, retval] IDispatch** value);
    [id(2), propget] HRESULT value([out, retval] VARIANT* currentValue);
    [id(2), propput] HRESULT value([in] VARIANT newValue);
    [id(3), propget] HRESULT ValStatus([out, retval] CapeValidationStatus* value);
    [id(4), propget] HRESULT Mode([out, retval] CapeParamMode* value);
    [id(4), propput] HRESULT Mode([in] CapeParamMode value);
    [id(5)] HRESULT Validate([in, out] BSTR* message, [out, retval] VARIANT_BOOL* isValid);
    [id(6)] HRESULT Reset();
};

[
    object,
    uuid(678C0A9B-0100-11D2-A67D-00105A42887F),
    dual,
    nonextensible,
    oleautomation,
    pointer_default(unique)
]
interface ICapeUtilities : IDispatch
{
    [id(1), propget] HRESULT Parameters([out, retval] IDispatch** value);
    [id(2), propget] HRESULT SimulationContext([out, retval] IDispatch** value);
    [id(2), propputref] HRESULT SimulationContext([in] IDispatch* value);
    [id(3)] HRESULT Initialize();
    [id(4)] HRESULT Terminate();
    [id(5)] HRESULT Edit([out, retval] LONG* value);
};

