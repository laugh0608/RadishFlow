    [id(2), propget] HRESULT direction([out, retval] CapePortDirection* value);
    [id(3), propget] HRESULT connectedObject([out, retval] IDispatch** value);
    [id(4)] HRESULT Connect([in] IDispatch* objectToConnect);
    [id(5)] HRESULT Disconnect();
};

[
